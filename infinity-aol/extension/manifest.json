{
  "manifest_version": 3,
  "name": "EasyFlow AI Extension",
  "version": "2.8.0",
  "description": "Section-by-section AOL autofill from EasyFlow AI prepared payloads.",
  "permissions": ["activeTab", "scripting", "storage"],
  "background": { "service_worker": "background.js" },
  "host_permissions": [
    "http://127.0.0.1:8797/*",
    "http://localhost:8797/*",
    "http://127.0.0.1:3000/*",
    "http://localhost:3000/*",
    "https://booking.easyloanfinance.com.au/*",
    "https://*.easyloanfinance.com.au/*",
    "https://*.onrender.com/*",
    "https://infynity.com.au/*",
    "https://*.infynity.com.au/*",
    "https://infinity.com.au/*",
    "https://*.infinity.com.au/*",
    "https://*.applyonline.com.au/*"
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "EasyFlow AI Extension",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.infynity.com.au/*",
        "https://infynity.com.au/*",
        "https://*.infinity.com.au/*",
        "https://infinity.com.au/*",
        "https://*.applyonline.com.au/*"
      ],
      "js": ["contentScript.infinityWorkflow.v4.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["mapping/infinity-aol-v1.json"],
      "matches": [
        "https://*.infynity.com.au/*",
        "https://*.infinity.com.au/*",
        "https://*.applyonline.com.au/*"
      ]
    }
  ]
}
