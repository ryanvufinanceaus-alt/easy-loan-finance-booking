PORT=3000
BOOKING_TIME_ZONE=Australia/Adelaide

# Protect the admin dashboard. Public /book links still work for clients.
ADMIN_EMAIL=ryan@easyloanfinance.com.au
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=

# Optional scale mode. Leave blank for free local JSON storage.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# New Supabase dashboards may show sb_secret_... instead of service_role.
# You can use either SUPABASE_SERVICE_ROLE_KEY or SUPABASE_SECRET_KEY.
SUPABASE_SECRET_KEY=

# Email alerts for every new public booking.
# Microsoft 365 example: SMTP_HOST=smtp.office365.com, SMTP_PORT=587, SMTP_SECURE=false
# Gmail example: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, SMTP_SECURE=false, use an app password.
BOOKING_NOTIFY_EMAIL=ryan@easyloanfinance.com.au
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Optional instant Google Calendar sync.
# Free fallback is still /calendar/team.ics and /calendar/broker/ryan-vu.ics.
GOOGLE_CALENDAR_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
# Alternative: paste the full service account JSON into GOOGLE_SERVICE_ACCOUNT_JSON instead.
GOOGLE_SERVICE_ACCOUNT_JSON=
