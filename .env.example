PORT=3000
BOOKING_TIME_ZONE=Australia/Adelaide

# Protect the admin dashboard. Public /book links still work for clients.
ADMIN_EMAIL=ryan.vufinanceaus@gmail.com
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=

# Optional scale mode. Leave blank for free local JSON storage.
SUPABASE_URL=
SUPABASE_SECRET_KEY=

# Email alerts for every new public booking.
# Current setup: Gmail SMTP with hello@easyloanfinance.com.au already verified as a Send mail as alias.
BOOKING_NOTIFY_EMAIL=ryan.vufinanceaus@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=ryan.vufinanceaus@gmail.com
SMTP_PASS=
SMTP_FROM=Easy Loan Finance <hello@easyloanfinance.com.au>
CLIENT_CONFIRMATION_EMAILS=true
CLIENT_CONFIRMATION_FROM=Easy Loan Finance <hello@easyloanfinance.com.au>
CLIENT_REPLY_TO=hello@easyloanfinance.com.au

# Optional instant Google Calendar sync.
# Free fallback is still /calendar/team.ics and /calendar/broker/ryan-vu.ics.
GOOGLE_CALENDAR_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
# Alternative: paste the full service account JSON into GOOGLE_SERVICE_ACCOUNT_JSON instead.
GOOGLE_SERVICE_ACCOUNT_JSON=
